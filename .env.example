PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
# IMPORTANT: value must start with mongodb:// or mongodb+srv:// and should not include `MONGO_URI=` prefix inside the value.
JWT_SECRET=change_me_please
JWT_EXPIRES_IN=30d
SEED_DEFAULT_USERS=true
DEFAULT_PASSWORD=1234
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://sampi-medline-uz.vercel.app
ALLOW_VERCEL_ORIGINS=true

